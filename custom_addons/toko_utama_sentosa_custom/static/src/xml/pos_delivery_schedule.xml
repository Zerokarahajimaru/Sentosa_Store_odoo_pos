<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Perbaikan: Inherit ke template Buttons, bukan Screen utama agar XPath ketemu -->
    <t t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('payment-buttons')]" position="before">
            <div class="custom-delivery-schedule mb-2 p-3 bg-white border rounded shadow-sm">
                <h5 class="mb-3 text-primary" style="font-size: 1.1rem;">
                    <i class="fa fa-truck me-2"></i> Jadwal Pengiriman &amp; Pickup
                </h5>
                <div class="form-group mb-3">
                    <label class="form-label fw-bold">Tanggal &amp; Waktu Kirim</label>
                    <input type="datetime-local" id="custom_delivery_date" class="form-control" />
                </div>
                <div class="form-check form-switch mt-2">
                    <input type="checkbox" class="form-check-input" id="custom_is_pickup" />
                    <label class="form-check-label fw-bold" for="custom_is_pickup">Kirim via Mobil Pickup Khusus</label>
                </div>
            </div>
        </xpath>
    </t>
</templates>
